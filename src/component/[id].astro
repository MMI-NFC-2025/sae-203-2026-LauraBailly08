---
interface Props {
	title?: string;
	subtitle?: string;
	description?: string;
	imageSrc?: string;
	imageAlt?: string;
	backHref?: string;
	backLabel?: string;
}

const {
	title = 'Element',
	subtitle = '',
	description = 'Le contenu detaille sera ajoute prochainement.',
	imageSrc = '/images/images/hero-du-site.avif',
	imageAlt = 'Image de couverture',
	backHref = '/',
	backLabel = 'Retour',
} = Astro.props;
---

<section class="relative w-full h-80 md:h-96 overflow-hidden">
	<img src={imageSrc} alt={imageAlt} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
	<div class="absolute inset-0 bg-black/45"></div>

	<div class="relative h-full max-w-6xl mx-auto px-4 flex flex-col justify-end pb-8 md:pb-10">
		<a href={backHref} class="text-white font-semibold mb-3 inline-flex items-center gap-2 hover:opacity-80 transition">
			<img src="/icones/flèche-gauche-carousel.svg" alt="Retour" class="w-4 h-4" />
			{backLabel}
		</a>

		{subtitle && <p class="text-white/90 font-semibold mb-2">{subtitle}</p>}
		<h1 class="text-4xl md:text-6xl font-bold text-white">{title}</h1>
	</div>
</section>

<section class="max-w-4xl mx-auto px-4 py-12 md:py-16">
	<h2 class="text-3xl font-bold text-gray-900 mb-4">Presentation</h2>
	<p class="text-lg text-gray-700 leading-relaxed">{description}</p>
</section>
