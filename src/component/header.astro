---
// Ici, tu peux ajouter de la logique côté serveur si besoin
---

<header class="w-full bg-white border-b border-gray-100 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 flex justify-between items-center h-20">
    
    <a href="/" class="flex-shrink-0">
      <img src="/assets/icones/logo-du-site.svg" alt="Logo La Fanfa'Comtoise" class="h-12 w-auto" />
    </a>

    <button 
      id="menu-toggle"
      class="inline-flex items-center justify-center p-2 rounded-md text-gray-700 md:hidden hover:bg-gray-100 focus:outline-none"
      aria-label="Ouvrir le menu de navigation"
    >
      <div class="space-y-1.5">
        <span class="block w-6 h-0.5 bg-current transform transition duration-300"></span>
        <span class="block w-6 h-0.5 bg-current transform transition duration-300"></span>
        <span class="block w-6 h-0.5 bg-current transform transition duration-300"></span>
      </div>
    </button>

    <nav 
      id="header-nav"
      class="absolute top-full left-0 w-full bg-white border-b border-gray-100 md:static md:w-auto md:border-none hidden md:block"
      aria-label="Navigation principale"
    >
      <ul class="flex flex-col md:flex-row md:items-center p-4 md:p-0 space-y-4 md:space-y-0 md:space-x-8">
        <li><a href="/" class="text-gray-700 hover:text-blue-600 font-medium transition-colors">Accueil</a></li>
        <li><a href="/le-festival" class="text-gray-700 hover:text-blue-600 font-medium transition-colors">Le Festival</a></li>
        <li><a href="/artistes" class="text-gray-700 hover:text-blue-600 font-medium transition-colors">Artistes</a></li>
        <li><a href="/programme" class="text-gray-700 hover:text-blue-600 font-medium transition-colors">Programme</a></li>
        <li><a href="/scenes" class="text-gray-700 hover:text-blue-600 font-medium transition-colors">Scènes</a></li>
        <li><a href="/infos-pratiques" class="text-gray-700 hover:text-blue-600 font-medium transition-colors">Infos Pratiques</a></li>
        <li><a href="/contact" class="text-gray-700 hover:text-blue-600 font-medium transition-colors underline decoration-blue-500 decoration-2 underline-offset-4">Contact</a></li>
      </ul>
    </nav>
  </div>
</header>

<script>
  // Petit script pour gérer l'ouverture du menu mobile
  const btn = document.getElementById('menu-toggle');
  const nav = document.getElementById('header-nav');

  btn?.addEventListener('click', () => {
    nav?.classList.toggle('hidden');
  });
</script>