---
// Ici, tu peux ajouter de la logique côté serveur si besoin
---

<header class="w-full bg-white border-b border-gray-100 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 flex justify-between items-center h-24">
    
    <!-- Logo -->
    <a href="/" class="shrink-0">
      <img src="/icones/logo-du-site.svg" alt="Logo La Fanfa'Comtoise" class="h-16 w-auto" />
    </a>

    <!-- Hamburger Menu Button - Always visible -->
    <button 
      id="menu-toggle"
      class="inline-flex items-center justify-center p-2 rounded-md text-gray-700 hover:bg-gray-100 focus:outline-none"
      aria-label="Ouvrir le menu de navigation"
    >
      <svg 
        id="menu-icon"
        class="w-8 h-8" 
        fill="none" 
        stroke="currentColor" 
        viewBox="0 0 24 24" 
        xmlns="http://www.w3.org/2000/svg"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <nav 
    id="mobile-menu"
    class="hidden bg-white border-t border-gray-100"
  >
    <ul class="flex flex-col p-4 space-y-4">
      <li><a href="/" class="text-gray-700 font-medium transition-colors hover:opacity-70" style="--hover-color: var(--color-primary)">Accueil</a></li>
      <li><a href="/le-festival" class="text-gray-700 font-medium transition-colors hover:opacity-70" style="--hover-color: var(--color-primary)">Le Festival</a></li>
      <li><a href="/artistes" class="text-gray-700 font-medium transition-colors hover:opacity-70" style="--hover-color: var(--color-primary)">Artistes</a></li>
      <li><a href="/programme" class="text-gray-700 font-medium transition-colors hover:opacity-70" style="--hover-color: var(--color-primary)">Programme</a></li>
      <li><a href="/scenes" class="text-gray-700 font-medium transition-colors hover:opacity-70" style="--hover-color: var(--color-primary)">Scènes</a></li>
      <li><a href="/infos-pratiques" class="text-gray-700 font-medium transition-colors hover:opacity-70" style="--hover-color: var(--color-primary)">Infos Pratiques</a></li>
      <li><a href="/contact" class="text-gray-700 font-medium transition-colors hover:opacity-70" style="--hover-color: var(--color-primary)">Contact</a></li>
    </ul>
  </nav>
</header>

<script>
  const btn = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>