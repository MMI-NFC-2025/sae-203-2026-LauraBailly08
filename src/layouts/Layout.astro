---
import '../styles/global.css';
import Header from '../component/header.astro';
import Footer from '../component/footer.astro';
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/favicon/favicons/favicon.ico?v=2" sizes="any" />
		<link rel="shortcut icon" href="/favicon/favicons/favicon.ico?v=2" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=1" />
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon/favicons/favicon-96x96.png?v=1" />
		<link rel="apple-touch-icon" sizes="180x180" href="/favicon/favicons/apple-touch-icon.png?v=1" />
		<link rel="manifest" href="/site.webmanifest?v=1" />
		<meta name="theme-color" content="#f5a623" />
		<meta name="generator" content={Astro.generator} />
		<title>La Fête Comtoise - Festival Jazz, Fanfares & Musiques de rue</title>
		<meta name="description" content="Festival gratuit et écologique à Montbéliard - Jazz, Fanfares & Musiques de rue" />
	</head>
	<body class="bg-white">
		<!-- Header Component -->
		<Header />

		<!-- Main Content -->
		<main>
			<slot />
		</main>

		<!-- Footer Component -->
		<Footer />
	</body>
</html>

