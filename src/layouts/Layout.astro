---
import '../styles/global.css';
import '@fontsource-variable/inter';
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>La Fête Comtoise - Festival Jazz, Fanfares & Musiques de rue</title>
		<meta name="description" content="Festival gratuit et écologique à Montbéliard - Jazz, Fanfares & Musiques de rue" />
	</head>
	<body class="bg-white">
		<!-- Header -->
		<header class="bg-white shadow-sm sticky top-0 z-50">
			<div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
				<a href="/" class="flex items-center gap-2 font-bold text-lg">
					<span class="text-2xl">🎭</span>
					<span>La Fête Comtoise</span>
				</a>
				<nav class="hidden md:flex gap-8">
					<a href="/" class="hover:text-orange-400 transition">Accueil</a>
					<a href="/artistes" class="hover:text-orange-400 transition">Artistes</a>
					<a href="/scenes" class="hover:text-orange-400 transition">Scènes</a>
					<a href="#" class="hover:text-orange-400 transition">Infos pratiques</a>
					<a href="#" class="hover:text-orange-400 transition">Contact</a>
				</nav>
				<button class="md:hidden text-2xl">☰</button>
			</div>
		</header>

		<!-- Main Content -->
		<main>
			<slot />
		</main>

		<!-- Footer -->
		<footer class="bg-gray-100">
			<div class="max-w-6xl mx-auto px-4 py-12">
				<div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-8">
					<div>
						<h3 class="font-bold text-lg mb-4">Navigation</h3>
						<ul class="space-y-2 text-sm">
							<li><a href="/" class="hover:text-orange-400 transition">Accueil</a></li>
							<li><a href="#" class="hover:text-orange-400 transition">Le Festival</a></li>
							<li><a href="#" class="hover:text-orange-400 transition">Artistes</a></li>
							<li><a href="#" class="hover:text-orange-400 transition">Scènes</a></li>
							<li><a href="#" class="hover:text-orange-400 transition">Contact</a></li>
						</ul>
					</div>
					<div class="hidden md:block">
					</div>
					<div>
						<h3 class="font-bold text-lg mb-4">Contact</h3>
						<p class="text-sm mb-2">📍 Place Saint-Martin</p>
						<p class="text-sm mb-2">25200 Montbéliard</p>
						<p class="text-sm mb-2">📧 contact@lafetecomtoise.fr</p>
						<p class="text-sm">☎️ 03 81 91 54 56</p>
					</div>
					<div>
						<h3 class="font-bold text-lg mb-4">Suivez-nous</h3>
						<div class="flex gap-4">
							<a href="#" class="text-2xl hover:text-orange-400 transition">📘</a>
							<a href="#" class="text-2xl hover:text-orange-400 transition">📷</a>
							<a href="#" class="text-2xl hover:text-orange-400 transition">🐦</a>
						</div>
					</div>
				</div>
				<hr class="border-gray-300 mb-6" />
				<p class="text-center text-sm text-gray-600">
					© 2025 La Fête Comtoise - Tous droits réservés
				</p>
			</div>
		</footer>
	</body>
</html>


