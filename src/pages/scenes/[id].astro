---
import Layout from '../../layouts/Layout.astro';
import { getSceneById, getScenesParNom } from '../../../backend/backend.mjs';
import PbImage from '../../lib/PbImage.astro';

export const prerender = true;

export async function getStaticPaths() {
  const scenes = await getScenesParNom();

  return scenes.map((scene) => ({
    params: { id: scene.id },
  }));
}

const { id } = Astro.params;
const scene = id ? await getSceneById(id) : null;

if (!scene) {
  return Astro.redirect('/scenes');
}

---

<Layout>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <a href="/scenes" class="inline-flex items-center gap-2 font-semibold mb-8 hover:opacity-80 transition" style="color: var(--color-primary);">
      <img src="/icones/flèche-gauche-carousel.svg" alt="Retour" class="w-5 h-5">
      Retour aux scenes
    </a>
  </div>

  <section class="relative w-full h-96 md:h-full overflow-hidden" style="max-height: 500px;">
    <PbImage
      record={scene}
      fieldName="photo_scene"
      fallback="/images/images/hero-du-site.avif"
      alt={scene.nom_scene || 'Scene'}
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/40 flex flex-col justify-end p-8 md:p-16">
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-6">{scene.nom_scene || 'Scene'}</h1>
      <div class="space-y-3">
        <div class="flex items-center gap-3 text-white">
          <img src="/icones/position.svg" alt="Localisation" class="w-5 h-5">
          <span>{scene.localisation || 'Localisation a confirmer'}</span>
        </div>
        <div class="flex items-center gap-3 text-white">
          <img src="/icones/public.svg" alt="Capacite" class="w-5 h-5">
          <span>Capacite : {scene.capacite || 'A confirmer'} personnes</span>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-16 md:py-24">
    <div class="flex items-start gap-4 mb-8">
      <span class="text-4xl pt-2" style="color: var(--color-primary);">●</span>
      <div>
        <h2 class="text-4xl font-bold text-gray-900">A propos de cette scene</h2>
      </div>
    </div>
    <p class="text-lg text-gray-600 leading-relaxed max-w-3xl">{scene.description_scene || 'Description a venir pour cette scene.'}</p>
  </section>

  <section class="bg-gray-50 py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-4xl font-bold text-gray-900 mb-12">Infos pratiques</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white p-8 rounded-lg shadow-md">
          <div class="flex items-start gap-4 mb-4">
            <img src="/icones/position.svg" alt="Localisation" class="w-8 h-8 shrink-0">
            <h3 class="text-xl font-bold text-gray-900">Localisation</h3>
          </div>
          <p class="text-gray-600 text-sm">{scene.localisation || 'Information indisponible'}</p>
        </div>

        <div class="bg-white p-8 rounded-lg shadow-md">
          <div class="flex items-start gap-4 mb-4">
            <img src="/icones/public.svg" alt="Capacite" class="w-8 h-8 shrink-0">
            <h3 class="text-xl font-bold text-gray-900">Capacite</h3>
          </div>
          <p class="text-gray-600 text-sm">{scene.capacite || 'Information indisponible'} personnes</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 text-center" style="background-color: var(--color-green-partners);">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">Pret a decouvrir cette scene ?</h2>
      <p class="text-lg text-gray-800 mb-8">Consultez le programme complet du festival pour connaitre tous les artistes qui s'y produiront.</p>
      <a href="/programme" class="inline-block px-8 py-4 bg-gray-900 text-white font-semibold rounded-lg hover:bg-gray-800 transition">
        Voir le programme
      </a>
    </div>
  </section>
</Layout>
