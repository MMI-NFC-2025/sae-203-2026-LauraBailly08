---
import Layout from '../layouts/Layout.astro';
---

<Layout title="La Fanfa'Comtoise - Festival de Musique">
    <!-- SECTION HERO -->
    <section class="relative w-full h-96 md:h-[500px] bg-cover bg-center overflow-hidden">
        <video autoplay muted loop class="absolute inset-0 w-full h-full object-cover">
            <source src="/video/videos/vidéo-festival.mp4" type="video/mp4">
        </video>
        <div class="absolute inset-0 bg-black/40"></div>
        <div class="relative flex flex-col justify-center items-center h-full px-4 text-center">
            <h1 class="text-4xl md:text-5xl font-bold text-black mb-8">Jazz, Fanfares & Musiques de Rues</h1>
            
            <div class="flex gap-6 mb-8 flex-wrap justify-center">
                <div class="flex items-center gap-2">
                    <img src="/icones/calendrier.svg" alt="calendrier" class="w-5 h-5">
                    <p class="text-black font-medium">27-29 juin 2025</p>
                </div>
                <div class="flex items-center gap-2">
                    <img src="/icones/position.svg" alt="position" class="w-5 h-5">
                    <p class="text-black font-medium">Montbéliard</p>
                </div>
            </div>
            
            <div class="flex gap-4 flex-wrap justify-center mb-8">
                <a href="/programme" class="flex items-center gap-2 px-6 py-3 rounded-full font-bold text-white bg-orange-400 transition hover:opacity-90">
                    <img src="/icones/music.svg" alt="musique" class="w-5 h-5">
                    Découvrir le programme
                </a>
                <a href="#billetterie" class="flex items-center gap-2 border-2 border-white text-white bg-transparent px-6 py-3 rounded-full font-bold hover:bg-white/20 transition">
                    <img src="/icones/ticket.svg" alt="ticket" class="w-5 h-5">
                    Billetterie
                </a>
            </div>
            
            <p class="flex items-center gap-2 text-black font-medium">
                <img src="/icones/eco.svg" alt="eco" class="w-5 h-5">
                Gratuit & Éco
            </p>
        </div>
    </section>

    <!-- SECTION STATISTIQUES -->
    <section class="w-full py-16 px-4" style="background-color: #FFFBF0">
        <div class="max-w-6xl mx-auto">
            <h2 class="text-3xl font-bold text-center mb-12">Le Festival en Chiffres</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                <article class="bg-white p-8 rounded-xl shadow-sm text-center border border-gray-100">
                    <span class="text-4xl block mb-4">🎤</span>
                    <h3 class="text-3xl font-bold mb-2 text-orange-400">6</h3>
                    <p class="font-semibold text-gray-800 mb-2">Artistes</p>
                    <p class="text-sm text-gray-600">Jazz, fanfares et musiques de rue</p>
                </article>

                <article class="bg-white p-8 rounded-xl shadow-sm text-center border border-gray-100">
                    <img src="/icones/eco.svg" alt="eco" class="w-10 h-10 mx-auto mb-4">
                    <h3 class="text-2xl font-bold mb-2 text-orange-400">100%</h3>
                    <p class="font-semibold text-gray-800 mb-2">Éco</p>
                    <p class="text-sm text-gray-600">Festival écoresponsable</p>
                </article>

                <article class="bg-white p-8 rounded-xl shadow-sm text-center border border-gray-100">
                    <span class="text-4xl block mb-4">🎉</span>
                    <h3 class="text-2xl font-bold mb-2 text-orange-400">Gratuit</h3>
                    <p class="font-semibold text-gray-800 mb-2">Accès libre</p>
                    <p class="text-sm text-gray-600">Ouvert à tous</p>
                </article>

                <article class="bg-white p-8 rounded-xl shadow-sm text-center border border-gray-100">
                    <img src="/icones/scène.svg" alt="scène" class="w-10 h-10 mx-auto mb-4">
                    <h3 class="text-3xl font-bold mb-2 text-orange-400">3</h3>
                    <p class="font-semibold text-gray-800 mb-2">Scènes</p>
                    <p class="text-sm text-gray-600">Centre-ville historique</p>
                </article>
            </div>
        </div>
    </section>

    <!-- SECTION DÉCOUVREZ LE FESTIVAL -->
    <section class="w-full py-16 px-4 bg-white">
        <div class="max-w-6xl mx-auto">
            <h2 class="text-3xl font-bold text-center mb-12">Découvrez le festival</h2>
            
            <div class="grid md:grid-cols-4 gap-6">
                <article class="bg-white p-6 rounded-lg border border-gray-200 hover:shadow-lg transition">
                    <img src="/icones/calendrier.svg" alt="calendrier" class="w-12 h-12 mb-4">
                    <h3 class="text-xl font-bold mb-2">Programme</h3>
                    <p class="text-gray-600 mb-4 text-sm">Découvrez tous les concerts et horaires des 3 jours</p>
                    <a href="/programme" class="font-bold text-orange-400 hover:opacity-80 transition">Voir le programme →</a>
                </article>

                <article class="bg-white p-6 rounded-lg border border-gray-200 hover:shadow-lg transition">
                    <img src="/icones/music.svg" alt="musique" class="w-12 h-12 mb-4">
                    <h3 class="text-xl font-bold mb-2">Artistes</h3>
                    <p class="text-gray-600 mb-4 text-sm">Rencontrez les artistes qui feront danser Montbéliard</p>
                    <a href="/artistes" class="font-bold text-orange-400 hover:opacity-80 transition">Voir les artistes →</a>
                </article>

                <article class="bg-white p-6 rounded-lg border border-gray-200 hover:shadow-lg transition">
                    <img src="/icones/scène.svg" alt="scènes" class="w-12 h-12 mb-4">
                    <h3 class="text-xl font-bold mb-2">Scènes</h3>
                    <p class="text-gray-600 mb-4 text-sm">Explorez les différentes scènes du festival</p>
                    <a href="/scenes" class="font-bold text-orange-400 hover:opacity-80 transition">Voir les scènes →</a>
                </article>

                <article class="bg-white p-6 rounded-lg border border-gray-200 hover:shadow-lg transition">
                    <img src="/icones/calendrier.svg" alt="infos" class="w-12 h-12 mb-4">
                    <h3 class="text-xl font-bold mb-2">Infos pratiques</h3>
                    <p class="text-gray-600 mb-4 text-sm">Tous les détails pour préparer votre visite</p>
                    <a href="/infos-pratiques" class="font-bold text-orange-400 hover:opacity-80 transition">Plus d'infos →</a>
                </article>
            </div>
        </div>
    </section>

    <!-- SECTION PARTENAIRES -->
    <section class="w-full py-16 px-4" style="background-color: #FFFBF0">
        <div class="max-w-6xl mx-auto">
            <h2 class="text-3xl font-bold text-center mb-12">Nos partenaires</h2>
            <div class="flex flex-wrap justify-center gap-8 items-center">
                <img src="/icones/Jaidemescommercants.fr-Partenaires-ville-montbeliard-09.svg" alt="Ville de Montbéliard" class="h-12 object-contain opacity-70 hover:opacity-100 transition">
                <img src="/icones/franche-comté-logo.svg" alt="Région" class="h-12 object-contain opacity-70 hover:opacity-100 transition">
                <img src="/icones/departement-doubs-logo.svg" alt="Doubs" class="h-12 object-contain opacity-70 hover:opacity-100 transition">
                <img src="/icones/Logo-Poudriere.svg" alt="La Poudière" class="h-12 object-contain opacity-70 hover:opacity-100 transition">
                <img src="/icones/moloco.svg" alt="Le Moloco" class="h-12 object-contain opacity-70 hover:opacity-100 transition">
                <img src="/icones/airbnb.svg" alt="Airbnb" class="h-12 object-contain opacity-70 hover:opacity-100 transition">
                <img src="/icones/Credit-Agricole-Logo.svg" alt="Crédit Agricole" class="h-12 object-contain opacity-70 hover:opacity-100 transition">
            </div>
        </div>
    </section>

    <!-- SECTION PRÉPAREZ VOTRE VENUE -->
    <section class="w-full py-16 px-4 bg-white">
        <div class="max-w-4xl mx-auto text-center">
            <h2 class="text-3xl font-bold mb-6">Préparez votre venue</h2>
            <p class="text-lg text-gray-700 mb-8">Téléchargez le programme complet et consultez toutes les informations pratiques</p>
            <div class="flex gap-4 flex-wrap justify-center">
                <a href="/programme.pdf" class="flex items-center gap-2 px-6 py-3 rounded-full font-bold text-white bg-orange-400 transition hover:opacity-90">
                    <img src="/icones/download.svg" alt="télécharger" class="w-5 h-5">
                    Télécharger le programme
                </a>
                <a href="/contact" class="border-2 border-orange-400 text-orange-400 px-6 py-3 rounded-full font-bold transition hover:opacity-80">
                    Nous contacter
                </a>
            </div>
        </div>
    </section>
</Layout>

