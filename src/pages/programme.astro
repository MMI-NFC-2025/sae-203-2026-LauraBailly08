---
import Layout from '../layouts/Layout.astro';
import { formatDateFr, formatDayFr, formatTimeFr, getArtistesParDate } from '../component/frontend-utils.mjs';

const artistes = await getArtistesParDate();

const artistesValides = artistes.filter((a) => Boolean(a.date_representation));
const groupes = artistesValides.reduce((acc, artiste) => {
    const key = artiste.date_representation?.slice(0, 10) || 'inconnu';
    if (!acc.has(key)) acc.set(key, []);
    acc.get(key)?.push(artiste);
    return acc;
}, new Map<string, typeof artistes>());

const programmeParJour = Array.from(groupes.entries())
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([jour, entries]) => ({ jour, entries }));
---

<Layout>
    <section class="relative w-full h-96 md:h-[80vh] overflow-hidden">
        <img src="/images/images/programme.avif" alt="Programme du festival" class="absolute inset-0 w-full h-full object-cover">
        <div class="absolute inset-0 bg-black/40"></div>
        <div class="relative h-full flex flex-col items-center justify-center text-center px-4">
            <div class="flex items-center gap-2 mb-4">
                <img src="/icones/calendrier.svg" alt="Calendrier" class="w-6 h-6">
                <span class="text-white font-bold">Programme en direct PocketBase</span>
            </div>
            <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">Programme</h1>
            <p class="text-lg md:text-2xl text-white max-w-3xl">Tous les concerts sont synchronises depuis votre base de donnees.</p>
        </div>
    </section>

    <section class="w-full py-16 px-4 bg-white">
        <div class="max-w-6xl mx-auto content-grid">
            {programmeParJour.length === 0 ? (
                <div class="lg:col-span-2 border border-gray-200 rounded-lg p-8 text-center text-gray-700">
                    Aucun concert planifie pour le moment.
                </div>
            ) : (
                programmeParJour.map((groupe) => (
                    <div class="bg-white rounded-lg overflow-hidden border border-gray-200">
                        <div class="flex items-center gap-4 p-4 md:p-6 border-b-4" style="border-color: var(--color-primary)">
                            <img src="/icones/calendrier.svg" alt="Date" class="w-6 h-6">
                            <div>
                                <h2 class="text-2xl font-bold text-gray-900" style="text-transform: capitalize;">{formatDayFr(groupe.jour)}</h2>
                                <p class="text-gray-600">{formatDateFr(groupe.jour)}</p>
                            </div>
                        </div>

                        <div class="divide-y">
                            {groupe.entries.map((artiste) => (
                                <article class="p-4 md:p-6 flex flex-col sm:flex-row items-start gap-4 sm:gap-6 hover:bg-gray-50 transition">
                                    <div class="flex flex-row sm:flex-col items-center gap-2 min-w-fit">
                                        <img src="/icones/horaire.svg" alt="Heure" class="w-5 h-5">
                                        <span class="font-bold text-lg" style="color: var(--color-primary)">{formatTimeFr(artiste.date_representation)}</span>
                                    </div>
                                    <div class="flex-1">
                                        <h3 class="text-lg md:text-xl font-bold text-gray-900 mb-2">{artiste.nom_artiste || 'Artiste sans nom'}</h3>
                                        <div class="flex flex-wrap items-center gap-4">
                                            <span class="px-3 py-1 rounded-full text-white text-sm font-bold" style="background-color: var(--color-primary)">
                                                {artiste.genre_musical || 'Genre a confirmer'}
                                            </span>
                                            <a href={`/artistes/${artiste.id}`} class="font-semibold hover:opacity-80" style="color: var(--color-primary)">
                                                Voir la fiche artiste
                                            </a>
                                        </div>
                                    </div>
                                </article>
                            ))}
                        </div>
                    </div>
                ))
            )}
        </div>
    </section>
</Layout>
