---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <!-- PAGE HEADER AVEC IMAGE DE FOND -->
    <section class="relative w-full h-96 md:h-screen overflow-hidden">
        <img src="/images/images/les-artistes.avif" alt="Les Artistes du festival" class="absolute inset-0 w-full h-full object-cover">
        <div class="absolute inset-0 bg-black/40"></div>
        <div class="relative h-full flex flex-col items-center justify-center text-center px-4">
            <div class="flex items-center gap-2 mb-4">
                <img src="/icones/music.svg" alt="Icône artistes" class="w-6 h-6">
                <span class="text-white font-bold">6 artistes</span>
            </div>
            <h1 class="text-5xl md:text-6xl font-bold text-white mb-4">Les Artistes</h1>
            <p class="text-xl md:text-2xl text-white max-w-3xl">Découvrez les talents jazz, fanfare et musiques de rue qui feront vibrer le festival</p>
        </div>
    </section>

    <!-- SECTION ARTISTES -->
    <section class="w-full py-16 px-4 bg-white">
        <div class="max-w-6xl mx-auto">
            <!-- Header avec tri -->
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-6">
                <h2 class="text-4xl font-bold text-gray-900">6 artistes programmés</h2>
                <div class="flex items-center gap-3">
                    <label for="sort-artists" class="font-semibold text-gray-700">Trier par :</label>
                    <select id="sort-artists" class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2" style="--tw-ring-color: var(--color-primary)">
                        <option value="date">Date</option>
                        <option value="name">Nom</option>
                        <option value="genre">Genre</option>
                    </select>
                </div>
            </div>

            <!-- Grille d'artistes -->
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- ARTISTE 1: Lazy Birds -->
                <article class="border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition">
                    <div class="relative h-48 bg-gray-200 overflow-hidden">
                        <img src="/images/images/lazy-birds.avif" alt="Lazy Birds" class="w-full h-full object-cover">
                        <span class="absolute top-3 right-3 px-3 py-1 rounded-full text-white text-sm font-bold" style="background-color: var(--color-primary)">Jazz</span>
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-4 text-gray-900">Lazy Birds</h3>
                        <div class="space-y-2 mb-4">
                            <div class="flex items-start gap-2 text-gray-600">
                                <img src="/icones/calendrier.svg" alt="Date" class="w-4 h-4 mt-0.5 shrink-0">
                                <span>27 juin 2025 à 20:00</span>
                            </div>
                            <div class="flex items-start gap-2 text-gray-600">
                                <img src="/icones/position.svg" alt="Lieu" class="w-4 h-4 mt-0.5 shrink-0">
                                <span>Place Saint-Martin</span>
                            </div>
                        </div>
                        <a href="/artistes/lazy-birds" class="font-bold transition hover:opacity-80" style="color: var(--color-primary)">En savoir plus →</a>
                    </div>
                </article>

                <!-- ARTISTE 2: FMR Orchestra -->
                <article class="border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition">
                    <div class="relative h-48 bg-gray-200 overflow-hidden">
                        <img src="/images/images/fmr-orcherstra.avif" alt="FMR Orchestra" class="w-full h-full object-cover">
                        <span class="absolute top-3 right-3 px-3 py-1 rounded-full text-white text-sm font-bold" style="background-color: #FF6B6B">Fanfare</span>
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-4 text-gray-900">FMR Orchestra</h3>
                        <div class="space-y-2 mb-4">
                            <div class="flex items-start gap-2 text-gray-600">
                                <img src="/icones/calendrier.svg" alt="Date" class="w-4 h-4 mt-0.5 shrink-0">
                                <span>28 juin 2025 à 18:30</span>
                            </div>
                            <div class="flex items-start gap-2 text-gray-600">
                                <img src="/icones/position.svg" alt="Lieu" class="w-4 h-4 mt-0.5 shrink-0">
                                <span>Scène des Halles</span>
                            </div>
                        </div>
                        <a href="/artistes/fmr-orchestra" class="font-bold transition hover:opacity-80" style="color: var(--color-primary)">En savoir plus →</a>
                    </div>
                </article>

                <!-- ARTISTE 3: What She Says -->
                <article class="border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition">
                    <div class="relative h-48 bg-gray-200 overflow-hidden">
                        <img src="/images/images/musique-de-rue.avif" alt="What She Says" class="w-full h-full object-cover">
                        <span class="absolute top-3 right-3 px-3 py-1 rounded-full text-white text-sm font-bold" style="background-color: #4ECDC4">Musique de rue</span>
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-4 text-gray-900">What She Says</h3>
                        <div class="space-y-2 mb-4">
                            <div class="flex items-start gap-2 text-gray-600">
                                <img src="/icones/calendrier.svg" alt="Date" class="w-4 h-4 mt-0.5 shrink-0">
                                <span>28 juin 2025 à 16:00</span>
                            </div>
                            <div class="flex items-start gap-2 text-gray-600">
                                <img src="/icones/position.svg" alt="Lieu" class="w-4 h-4 mt-0.5 shrink-0">
                                <span>Place Saint-Martin</span>
                            </div>
                        </div>
                        <a href="/artistes/what-she-says" class="font-bold transition hover:opacity-80" style="color: var(--color-primary)">En savoir plus →</a>
                    </div>
                </article>

                <!-- ARTISTE 4: Black Chicks -->
                <article class="border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition">
                    <div class="relative h-48 bg-gray-200 overflow-hidden">
                        <img src="/images/images/lazy-birds.avif" alt="Black Chicks" class="w-full h-full object-cover">
                        <span class="absolute top-3 right-3 px-3 py-1 rounded-full text-white text-sm font-bold" style="background-color: var(--color-primary)">Jazz Soul</span>
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-4 text-gray-900">Black Chicks</h3>
                        <div class="space-y-2 mb-4">
                            <div class="flex items-start gap-2 text-gray-600">
                                <img src="/icones/calendrier.svg" alt="Date" class="w-4 h-4 mt-0.5 shrink-0">
                                <span>29 juin 2025 à 21:00</span>
                            </div>
                            <div class="flex items-start gap-2 text-gray-600">
                                <img src="/icones/position.svg" alt="Lieu" class="w-4 h-4 mt-0.5 shrink-0">
                                <span>Place Saint-Martin</span>
                            </div>
                        </div>
                        <a href="/artistes/black-chicks" class="font-bold transition hover:opacity-80" style="color: var(--color-primary)">En savoir plus →</a>
                    </div>
                </article>

                <!-- ARTISTE 5: Le Collectif Jazz 25 -->
                <article class="border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition">
                    <div class="relative h-48 bg-gray-200 overflow-hidden">
                        <img src="/images/images/scène-éco.avif" alt="Le Collectif Jazz 25" class="w-full h-full object-cover">
                        <span class="absolute top-3 right-3 px-3 py-1 rounded-full text-white text-sm font-bold" style="background-color: var(--color-primary)">Jazz</span>
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-4 text-gray-900">Le Collectif Jazz 25</h3>
                        <div class="space-y-2 mb-4">
                            <div class="flex items-start gap-2 text-gray-600">
                                <img src="/icones/calendrier.svg" alt="Date" class="w-4 h-4 mt-0.5 shrink-0">
                                <span>29 juin 2025 à 15:00</span>
                            </div>
                            <div class="flex items-start gap-2 text-gray-600">
                                <img src="/icones/position.svg" alt="Lieu" class="w-4 h-4 mt-0.5 shrink-0">
                                <span>Scène du Parc</span>
                            </div>
                        </div>
                        <a href="/artistes/collectif-jazz-25" class="font-bold transition hover:opacity-80" style="color: var(--color-primary)">En savoir plus →</a>
                    </div>
                </article>

                <!-- ARTISTE 6: À annoncer -->
                <article class="border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition">
                    <div class="relative h-48 bg-gray-200 overflow-hidden">
                        <img src="/images/images/programme.avif" alt="À annoncer" class="w-full h-full object-cover">
                        <span class="absolute top-3 right-3 px-3 py-1 rounded-full text-white text-sm font-bold" style="background-color: #FF6B6B">Fanfare</span>
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-4 text-gray-900">À annoncer</h3>
                        <div class="space-y-2 mb-4">
                            <div class="flex items-start gap-2 text-gray-600">
                                <img src="/icones/calendrier.svg" alt="Date" class="w-4 h-4 mt-0.5 shrink-0">
                                <span>Dates à confirmer</span>
                            </div>
                            <div class="flex items-start gap-2 text-gray-600">
                                <img src="/icones/position.svg" alt="Lieu" class="w-4 h-4 mt-0.5 shrink-0">
                                <span>Lieu à confirmer</span>
                            </div>
                        </div>
                        <a href="#" class="font-bold transition hover:opacity-80" style="color: var(--color-primary)">En savoir plus →</a>
                    </div>
                </article>
            </div>
        </div>
    </section>

    <!-- SECTION CTA -->
    <section class="w-full py-16 px-4" style="background-color: var(--color-green-partners)">
        <div class="max-w-6xl mx-auto">
            <img src="/icones/music.svg" alt="Icône musique" class="w-8 h-8 mb-6">
            <h2 class="text-4xl font-bold mb-4 text-gray-900">Ne manquez aucun concert</h2>
            <p class="text-lg text-gray-800 mb-8 max-w-2xl">Consultez le programme complet pour organiser votre weekend musical</p>
            <a href="/programme" class="inline-block px-8 py-3 rounded-full font-bold text-white transition hover:opacity-90" style="background-color: var(--color-primary)">Voir le programme complet</a>
        </div>
    </section>
</Layout>
