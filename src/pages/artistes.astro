---
import Layout from '../layouts/Layout.astro';
import { formatDateFr, formatTimeFr, getArtistesParDate } from '../../backend/backend.mjs';
import PbImage from '../lib/PbImage.astro';

const artistes = await getArtistesParDate();
---

<Layout>
    <section class="relative w-full h-96 md:h-[80vh] overflow-hidden">
        <img src="/images/images/les-artistes.avif" alt="Les artistes du festival" class="absolute inset-0 w-full h-full object-cover">
        <div class="absolute inset-0 bg-black/40"></div>
        <div class="relative h-full flex flex-col items-center justify-center text-center px-4">
            <div class="flex items-center gap-2 mb-4">
                <img src="/icones/music.svg" alt="Icone artistes" class="w-6 h-6">
                <span class="text-white font-bold">{artistes.length} artistes</span>
            </div>
            <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">Les Artistes</h1>
            <p class="text-lg md:text-2xl text-white max-w-3xl">Decouvrez les talents jazz, fanfare et musiques de rue du festival.</p>
        </div>
    </section>

    <section class="w-full py-16 px-4 bg-white">
        <div class="max-w-6xl mx-auto">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-6">
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900">{artistes.length} artistes programmes</h2>
                <a href="/programme" class="font-bold transition hover:opacity-80" style="color: var(--color-primary)">Voir le programme</a>
            </div>

            {artistes.length === 0 ? (
                <div class="border border-gray-200 rounded-lg p-8 text-center text-gray-700">
                    Aucun artiste disponible pour le moment.
                </div>
            ) : (
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {artistes.map((artiste) => (
                        <article class="border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition">
                            <div class="relative h-48 bg-gray-200 overflow-hidden">
                                <PbImage
                                    record={artiste}
                                    fieldName="photo_principal"
                                    fallback="/images/images/les-artistes.avif"
                                    alt={artiste.nom_artiste || 'Artiste'}
                                    class="w-full h-full object-cover"
                                />
                                <span class="absolute top-3 right-3 px-3 py-1 rounded-full text-white text-sm font-bold" style="background-color: var(--color-primary)">
                                    {artiste.genre_musical || 'Genre a confirmer'}
                                </span>
                            </div>
                            <div class="p-6">
                                <h3 class="text-xl font-bold mb-4 text-gray-900">{artiste.nom_artiste || 'Artiste sans nom'}</h3>
                                <div class="space-y-2 mb-4">
                                    <div class="flex items-start gap-2 text-gray-600">
                                        <img src="/icones/calendrier.svg" alt="Date" class="w-4 h-4 mt-0.5 shrink-0">
                                        <span>{formatDateFr(artiste.date_representation)} a {formatTimeFr(artiste.date_representation)}</span>
                                    </div>
                                    <p class="text-gray-600 line-clamp-3">{artiste.descritpion || 'Description a venir.'}</p>
                                </div>
                                <a href={`/artistes/${artiste.id}`} class="font-bold transition hover:opacity-80" style="color: var(--color-primary)">En savoir plus -></a>
                            </div>
                        </article>
                    ))}
                </div>
            )}
        </div>
    </section>

    <section class="w-full py-16 px-4" style="background-color: var(--color-green-partners)">
        <div class="max-w-6xl mx-auto">
            <img src="/icones/music.svg" alt="Icone musique" class="w-8 h-8 mb-6">
            <h2 class="text-3xl md:text-4xl font-bold mb-4 text-gray-900">Ne manquez aucun concert</h2>
            <p class="text-base md:text-lg text-gray-800 mb-8 max-w-2xl">Consultez le programme complet pour organiser votre weekend musical.</p>
            <a href="/programme" class="inline-block w-full sm:w-auto text-center px-8 py-3 rounded-full font-bold text-white transition hover:opacity-90" style="background-color: var(--color-primary)">Voir le programme complet</a>
        </div>
    </section>
</Layout>
