---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Page Header -->
  <section class="py-20 px-4 md:px-6 text-center bg-gray-50">
    <h1 class="text-5xl md:text-6xl font-bold text-gray-900 mb-4">Infos Pratiques</h1>
    <p class="text-xl text-gray-600 max-w-2xl mx-auto">Tout ce qu'il faut savoir pour profiter pleinement du festival</p>
  </section>

  <!-- Tarifs Section -->
  <section class="max-w-6xl mx-auto px-4 py-16 md:py-24">
    <div class="flex items-center gap-4 mb-12">
      <img src="/icones/ticket.svg" alt="Tarifs" class="w-8 h-8">
      <h2 class="text-4xl font-bold text-gray-900">Tarifs</h2>
    </div>

    <!-- Festival is Free -->
    <div class="bg-gradient-to-r from-amber-50 to-orange-50 p-8 md:p-12 rounded-lg mb-8 border-2" style="border-color: var(--color-primary);">
      <div class="flex items-start gap-4 mb-4">
        <img src="/icones/gratuit.svg" alt="Gratuit" class="w-12 h-12 shrink-0">
        <div>
          <h3 class="text-2xl font-bold text-gray-900 mb-2">Festival 100% Gratuit !</h3>
          <p class="text-lg text-gray-700">L'entrée au festival est totalement gratuite et ouverte à tous. Aucune réservation nécessaire.</p>
        </div>
      </div>
    </div>

    <!-- Food & Drinks -->
    <div class="bg-white p-8 md:p-12 rounded-lg shadow-md">
      <h3 class="text-2xl font-bold text-gray-900 mb-6">Restauration & Boissons</h3>
      <ul class="space-y-3 text-lg text-gray-700">
        <li class="flex items-start gap-3">
          <span class="text-orange-500 font-bold mt-1">•</span>
          <span><strong>Caution gobelet réutilisable :</strong> 1€ (remboursée lors du retour)</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-orange-500 font-bold mt-1">•</span>
          <span><strong>Boissons :</strong> 2€ - 5€</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-orange-500 font-bold mt-1">•</span>
          <span><strong>Restauration locale :</strong> 5€ - 12€</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-orange-500 font-bold mt-1">•</span>
          <span>Stands de producteurs bio et locaux</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- Hébergements Section -->
  <section class="bg-gray-50 py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex items-center gap-4 mb-12">
        <img src="/icones/apartment.svg" alt="Hébergements" class="w-8 h-8">
        <h2 class="text-4xl font-bold text-gray-900">Hébergements</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Hotels -->
        <div class="bg-white p-8 rounded-lg shadow-md">
          <div class="flex items-center gap-3 mb-6">
            <img src="/icones/villa.svg" alt="Hôtels" class="w-6 h-6">
            <h3 class="text-2xl font-bold text-gray-900">Hôtels</h3>
          </div>

          <div class="space-y-6">
            <div>
              <h4 class="text-lg font-bold text-gray-900 mb-2">Hôtel de la Balance</h4>
              <p class="text-gray-600 text-sm">40 Rue de Belfort, Montbéliard<br>À 5 min à pied du festival</p>
            </div>

            <div>
              <h4 class="text-lg font-bold text-gray-900 mb-2">Ibis Montbéliard</h4>
              <p class="text-gray-600 text-sm">5 Rue Georges Pompidon<br>À 10 min à pied du festival</p>
            </div>

            <div>
              <h4 class="text-lg font-bold text-gray-900 mb-2">BNB Hotel</h4>
              <p class="text-gray-600 text-sm">25C 59 Red des Gourties<br>À 15 min en bus</p>
            </div>
          </div>
        </div>

        <!-- Chambres d'hôtes -->
        <div class="bg-white p-8 rounded-lg shadow-md">
          <div class="flex items-center gap-3 mb-6">
            <img src="/icones/bed.svg" alt="Chambres d'hôtes" class="w-6 h-6">
            <h3 class="text-2xl font-bold text-gray-900">Chambres d'hôtes</h3>
          </div>
          <p class="text-gray-600 text-lg">Plusieurs options d'hébergement chez l'habitant disponibles à proximité du festival. Contactez-nous pour plus d'informations.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Accès & Transport Section -->
  <section class="max-w-6xl mx-auto px-4 py-16 md:py-24">
    <div class="flex items-center gap-4 mb-12">
      <img src="/icones/train.svg" alt="Accès & Transport" class="w-8 h-8">
      <h2 class="text-4xl font-bold text-gray-900">Accès & Transport</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- En train -->
      <div class="bg-white p-8 rounded-lg shadow-md">
        <div class="flex items-center gap-3 mb-6">
          <img src="/icones/train.svg" alt="Train" class="w-6 h-6">
          <h3 class="text-xl font-bold text-gray-900">En train</h3>
        </div>
        <div class="space-y-3 text-gray-700">
          <p><strong>Gare de Montbéliard :</strong> À 15 min à pied du centre-ville.</p>
          <ul class="space-y-2 text-sm">
            <li class="flex items-start gap-2">
              <span style="color: var(--color-primary);" class="font-bold">→</span>
              <span>Depuis Paris : 2h50 (TGV via Belfort)</span>
            </li>
            <li class="flex items-start gap-2">
              <span style="color: var(--color-primary);" class="font-bold">→</span>
              <span>Depuis Lyon : 3h</span>
            </li>
            <li class="flex items-start gap-2">
              <span style="color: var(--color-primary);" class="font-bold">→</span>
              <span>Depuis Besançon : 45 min</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- En voiture -->
      <div class="bg-white p-8 rounded-lg shadow-md">
        <div class="flex items-center gap-3 mb-6">
          <img src="/icones/voiture.svg" alt="Voiture" class="w-6 h-6">
          <h3 class="text-xl font-bold text-gray-900">En voiture</h3>
        </div>
        <div class="space-y-4 text-gray-700">
          <p><strong>Accès par l'A36 (sortie Montbéliard Centre)</strong></p>
          <div>
            <p class="font-bold mb-2">Parkings gratuits :</p>
            <ul class="space-y-2 text-sm">
              <li class="flex items-start gap-2">
                <span style="color: var(--color-primary);" class="font-bold">•</span>
                <span>Parking du Champ-de-Foire (500 places) - 10 min à pied</span>
              </li>
              <li class="flex items-start gap-2">
                <span style="color: var(--color-primary);" class="font-bold">•</span>
                <span>Parking de la Gare (300 places) - 15 min à pied</span>
              </li>
              <li class="flex items-start gap-2">
                <span style="color: var(--color-primary);" class="font-bold">•</span>
                <span>Parking des Halles (200 places) - 5 min à pied</span>
              </li>
            </ul>
          </div>
          <div class="bg-amber-50 p-3 rounded border-l-4" style="border-color: var(--color-primary);">
            <p class="text-sm font-semibold text-gray-900">💡 Privilégiez le covoiturage ! L'hôtelier d'autres habitants ou des groupes Facebook du festival.</p>
          </div>
        </div>
      </div>

      <!-- Transport doux -->
      <div class="bg-white p-8 rounded-lg shadow-md">
        <div class="flex items-center gap-3 mb-6">
          <img src="/icones/bike.svg" alt="Transport doux" class="w-6 h-6">
          <h3 class="text-xl font-bold text-gray-900">Transport doux</h3>
        </div>
        <ul class="space-y-3 text-sm text-gray-700">
          <li class="flex items-start gap-2">
            <span style="color: var(--color-primary);" class="font-bold">•</span>
            <span><strong>Vélo :</strong> Pistes cyclables sécurisées à proximité de chaque scène</span>
          </li>
          <li class="flex items-start gap-2">
            <span style="color: var(--color-primary);" class="font-bold">•</span>
            <span><strong>Bus :</strong> Lignes 1, 2 et 3 du réseau CTPM, arrêt "Place Saint-Martin"</span>
          </li>
          <li class="flex items-start gap-2">
            <span style="color: var(--color-primary);" class="font-bold">•</span>
            <span><strong>Trottinette/Vélo en libre-service :</strong> Plusieurs stations Véli-Go à proximité du centre-ville</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="bg-gray-50 py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4">
      <div class="flex items-center gap-4 mb-12">
        <img src="/icones/help.svg" alt="Questions" class="w-8 h-8">
        <h2 class="text-4xl font-bold text-gray-900">Questions fréquentes</h2>
      </div>

      <div class="space-y-4">
        <!-- FAQ 1 -->
        <details class="group bg-white rounded-lg overflow-hidden shadow-md">
          <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-gray-50 transition">
            <span class="text-lg font-semibold text-gray-900">Le festival est-il vraiment gratuit ?</span>
            <span class="text-2xl text-gray-600 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <div class="px-6 pb-6 text-gray-700 border-t border-gray-200">
            <p>Oui, l'entrée au festival est totalement gratuite. Aucune réservation n'est nécessaire. Seuls les consommations à titre optionnel (boissons, restauration) sont payants.</p>
          </div>
        </details>

        <!-- FAQ 2 -->
        <details class="group bg-white rounded-lg overflow-hidden shadow-md">
          <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-gray-50 transition">
            <span class="text-lg font-semibold text-gray-900">Comment le festival respecte-t-il l'environnement ?</span>
            <span class="text-2xl text-gray-600 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <div class="px-6 pb-6 text-gray-700 border-t border-gray-200">
            <p>La Fanfa'Comtoise s'engage pour l'écoresponsabilité : gestion des déchets, gobelets réutilisables, restauration bio et locale, transport doux encouragé, et une scène en pleine nature pour minimiser l'impact environnemental.</p>
          </div>
        </details>

        <!-- FAQ 3 -->
        <details class="group bg-white rounded-lg overflow-hidden shadow-md">
          <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-gray-50 transition">
            <span class="text-lg font-semibold text-gray-900">Peut-on venir avec des enfants ?</span>
            <span class="text-2xl text-gray-600 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <div class="px-6 pb-6 text-gray-700 border-t border-gray-200">
            <p>Bien sûr ! Le festival est familial et accueille les enfants de tous les âges. Des zones d'ombre et de repos sont aménagées à proximité de chaque scène pour leur confort.</p>
          </div>
        </details>

        <!-- FAQ 4 -->
        <details class="group bg-white rounded-lg overflow-hidden shadow-md">
          <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-gray-50 transition">
            <span class="text-lg font-semibold text-gray-900">Où peut-on se restaurer ?</span>
            <span class="text-2xl text-gray-600 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <div class="px-6 pb-6 text-gray-700 border-t border-gray-200">
            <p>Des stands de restauration locale et bio sont présents à proximité de chaque scène. Vous pourrez déguster des spécialités locales, des plats végétariens, des boissons, et bien d'autres délices culinaires.</p>
          </div>
        </details>

        <!-- FAQ 5 -->
        <details class="group bg-white rounded-lg overflow-hidden shadow-md">
          <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-gray-50 transition">
            <span class="text-lg font-semibold text-gray-900">Le festival est-il accessible aux personnes à mobilité réduite ?</span>
            <span class="text-2xl text-gray-600 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <div class="px-6 pb-6 text-gray-700 border-t border-gray-200">
            <p>Oui, toutes les scènes sont accessibles PMR. Des zones de stationnement réservées sont disponibles à proximité immédiate du festival. N'hésitez pas à nous contacter pour des besoins spécifiques.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-24 text-center" style="background-color: var(--color-green-partners);">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">Une question ?</h2>
      <p class="text-lg text-gray-800 mb-8">Vous ne trouvez pas la réponse à votre question ? N'hésitez pas à nous contacter !</p>
      <a href="/contact" class="inline-block px-8 py-4 bg-gray-900 text-white font-semibold rounded-lg hover:bg-gray-800 transition">
        Nous contacter
      </a>
    </div>
  </section>
</Layout>
